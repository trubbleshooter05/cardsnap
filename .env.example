# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: recommended for API routes and shared result pages (bypass RLS for inserts/reads)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# eBay Browse API — Production client credentials (required for live comps)
EBAY_APP_ID=
EBAY_CERT_ID=
# Leave unset in production; overrides client-credentials when set
# EBAY_OAUTH_TOKEN=

# eBay Partner Network (affiliate — partnernetwork.ebay.com)
EBAY_EPN_CAMPID=
NEXT_PUBLIC_EBAY_EPN_CAMPID=

# PSA (reserved for a future official API; pop data uses public search HTML when possible)
PSA_API_KEY=

# Stripe (webhook URL in Stripe: https://YOUR_DOMAIN/api/webhooks/stripe — use Signing secret from that endpoint)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pro subscription: monthly recurring (e.g. $9.99/mo)
STRIPE_PRICE_ID=
# Pro subscription: yearly recurring ($99/yr unlimited)
STRIPE_PRICE_ID_ANNUAL=price_1TVCxw0d0P07z4ppaBpZxQcF
# One-time scan packs (payment mode Checkout) — must match UI: $9.99 / $29 / $79
STRIPE_PRICE_ID_SCAN_PACK_10=price_1Tlerw0d0P07z4ppAmsX71c3
STRIPE_PRICE_ID_SCAN_PACK_50=price_1Tlerx0d0P07z4ppir7KrxfH
STRIPE_PRICE_ID_SCAN_PACK_200=price_1Tlerx0d0P07z4ppBYrnSrsF
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: internal insights microservice URL (server-side proxy only).
# Omit to show curated homepage “trending topics” fallback.
INSIGHTS_API_BASE_URL=

# Comma-separated operator emails with unlimited scans (server-only)
CARDSNAP_ADMIN_EMAILS=

# App URL for Stripe redirects (production: https://your-domain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "1" to reserve display-ad banner slots on some pages (off by default; no empty boxes when unset).
NEXT_PUBLIC_CARD_AD_SLOTS=

RESEND_API_KEY=
RESEND_FROM=
