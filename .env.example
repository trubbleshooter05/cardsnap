# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: recommended for API routes and shared result pages (bypass RLS for inserts/reads)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# eBay (use EBAY_OAUTH_TOKEN OR client credentials)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_OAUTH_TOKEN=

# PSA (reserved for a future official API; pop data uses public search HTML when possible)
PSA_API_KEY=

# Stripe (webhook URL in Stripe: https://YOUR_DOMAIN/api/webhooks/stripe — use Signing secret from that endpoint)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App URL for Stripe redirects (production: https://your-domain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (optional transactional email)
RESEND_API_KEY=
RESEND_FROM=
