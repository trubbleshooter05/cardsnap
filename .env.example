# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: recommended for API routes and shared result pages (bypass RLS for inserts/reads)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# eBay (use EBAY_OAUTH_TOKEN OR client credentials)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_OAUTH_TOKEN=

# PSA (reserved for a future official API; pop data uses public search HTML when possible)
PSA_API_KEY=

# Stripe (webhook URL in Stripe: https://YOUR_DOMAIN/api/webhooks/stripe — use Signing secret from that endpoint)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pro subscription: monthly recurring (e.g. $9.99/mo)
STRIPE_PRICE_ID=
# Pro subscription: yearly recurring ($99/yr unlimited)
STRIPE_PRICE_ID_ANNUAL=price_1TVCxw0d0P07z4ppaBpZxQcF
# One-time scan packs (payment mode Checkout)
STRIPE_PRICE_ID_SCAN_PACK_10=price_1TVD290d0P07z4ppQgfdABfy
STRIPE_PRICE_ID_SCAN_PACK_50=price_1TVD2m0d0P07z4ppZGXDHILH
STRIPE_PRICE_ID_SCAN_PACK_200=price_1TVD3L0d0P07z4ppZzZFoq6B
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App URL for Stripe redirects (production: https://your-domain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (optional transactional email)
RESEND_API_KEY=
RESEND_FROM=
